const express = require("express");
const bodyParser = require("body-parser");
const cors = require("cors");

const app = express();
const port = 3000;

app.use(cors());
app.use(bodyParser.json());

// Exemple de clients fictifs (tu pourras connecter une vraie base plus tard)
let clients = [
  { id: 1, nom: "Jean Dupont", email: "jean@example.com", statut: "Prospect" },
  { id: 2, nom: "Marie Durand", email: "marie@example.com", statut: "Client" },
];

// ✅ Lister les clients
app.get("/api/clients", (req, res) => {
  res.json(clients);
});

// ✅ Ajouter un client
app.post("/api/clients", (req, res) => {
  const nouveauClient = { ...req.body, id: Date.now() };
  clients.push(nouveauClient);
  res.status(201).json(nouveauClient);
});

// ✅ Agent IA (mock — tu pourras connecter ChatGPT ensuite)
app.post("/api/agent", (req, res) => {
  const message = req.body.message;
  const reponse = `Tu m'as dit : "${message}", je suis un agent IA en construction.`;
  res.json({ reponse });
});

// ✅ Lancer le serveur
app.listen(port, () => {
  console.log(`CRM IA backend lancé sur http://localhost:${port}`);
});
